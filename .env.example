# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# Required: URL of the deployed Google Apps Script web app (see sheets_webapp.gs)
# After deploying, it looks like: https://script.google.com/macros/s/AKfycb.../exec
SHEETS_WEBAPP_URL=

# Optional: override the Anthropic API key (uses ANTHROPIC_API_KEY by default)
# ANTHROPIC_API_KEY=sk-ant-...
